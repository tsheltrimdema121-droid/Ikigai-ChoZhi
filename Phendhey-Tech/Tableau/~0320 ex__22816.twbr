      <column datatype='real' name='[Calculation1]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ZN(AVG([phone_hours_before_sleep_numeric])) - LOOKUP(ZN(AVG([phone_hours_before_sleep_numeric])), -1)'>
          <table-calc ordering-type='Columns' />
        </calculation>
