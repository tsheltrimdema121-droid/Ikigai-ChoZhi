      </column>
      <column caption='RSleepOut' datatype='real' name='[Calculation_0499225089212417]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='POWER(CORR([sleep_hours_per_night_numeric], [Pivot Field Values]),2)' />
