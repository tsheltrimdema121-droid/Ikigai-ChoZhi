      <column datatype='real' name='[Calculation1]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ZN(AVG([phone_hours_before_sleep_numeric])) - LOOKUP(ZN(AVG([phone_hours_before_sleep_numeric])), -1)'>
          <table-calc ordering-type='Columns' />
        </calculation>
      </column>
      <column datatype='real' name='[Calculation2]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ZN(AVG([sleep_hours_per_night_numeric])) - LOOKUP(ZN(AVG([sleep_hours_per_night_numeric])), FIRST())'>
          <table-calc ordering-type='CellInPane' />
        </calculation>
      </column>
      <column caption='%' datatype='real' default-format='p0.00%' name='[Calculation4]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([serial_number]) / TOTAL(COUNTD([serial_number]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='CORworkingOUt' datatype='real' name='[Calculation_0239737568182272]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CORR([working_hours], [Pivot Field Values])' />
      </column>
      <column caption='CORRScreenOut' datatype='real' name='[Calculation_0239737591046146]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CORR([phone_hours_before_sleep_numeric], [Pivot Field Values])' />
      </column>
      <column caption='CORsleephoursOUT' datatype='real' name='[Calculation_0239737591336963]' role='measure' type='quantitative'>
