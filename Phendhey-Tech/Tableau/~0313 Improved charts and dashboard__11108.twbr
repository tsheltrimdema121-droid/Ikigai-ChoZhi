      <column caption='App used' datatype='string' name='[Calculation_1344475704393733]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [sleep_app_used_code] = 1 THEN &quot;Sleep Tracker App&quot;&#13;&#10;ELSEIF [sleep_app_used_code] = 2 THEN &quot;Health App&quot;&#13;&#10;ELSEIF [sleep_app_used_code] = 3 THEN &quot;Samsung Health App&quot;&#13;&#10;ELSEIF [sleep_app_used_code] = 4 THEN &quot;Alarm App&quot;&#13;&#10;ELSEIF [sleep_app_used_code] = 5 THEN &quot;My Health App&quot;&#13;&#10;ELSEIF [sleep_app_used_code] = 6 THEN &quot;Wearable App&quot;&#13;&#10;ELSEIF [sleep_app_used_code] = 7 THEN &quot;HryFine App&quot;&#13;&#10;ELSEIF [sleep_app_used_code] = 8 THEN &quot;Unspecified&quot;&#13;&#10;ELSE &quot;No Response&quot;&#13;&#10;END' />
      </column>
