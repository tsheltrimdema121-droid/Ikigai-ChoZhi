      <column caption='RScreenOut' datatype='real' name='[Calculation_0499225091538947]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='POWER(CORR([phone_hours_before_sleep_numeric], [Pivot Field Values]),2)' />
