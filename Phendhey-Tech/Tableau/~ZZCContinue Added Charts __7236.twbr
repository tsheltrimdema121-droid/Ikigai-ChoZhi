        <calculation class='tableau' formula='IF [gender_code] = 1 THEN &quot;Male&quot;&#13;&#10;ELSEIF [gender_code] = 2 THEN &quot;Female&quot;&#13;&#10;ELSE &quot;Not answered&quot;&#13;&#10;END' />
